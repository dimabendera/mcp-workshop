# ======================================
# LiteLLM Proxy (OpenAI-сумісний API)
# URL і ключ отримайте у ведучого
# ======================================
LITELLM_BASE_URL=https://YOUR_LITELLM_HOST/v1
LITELLM_API_KEY=sk-your-api-key
LLM_MODEL=ria_llm_latest

# ======================================
# Langfuse (трасування) — Крок 6
# ======================================
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_BASEURL=http://YOUR_LANGFUSE_HOST

# ======================================
# MCP HTTP Server — Крок 6
# ======================================
MCP_SECRET=your-mcp-bearer-token
PORT=3000
